---
// First-visit-per-session boot overlay. Sits on top of everything until done.
---

<div id="boot" aria-hidden="true">
  <div class="boot-stack">
    <div class="line big" id="boot-title" data-text="BHLONGGUL OS">BHLONGGUL OS</div>
    <div class="line" style="animation-delay: 900ms">> SYSTEM INITIALIZING<span class="dots"></span></div>
    <div class="line dim" style="animation-delay: 1200ms">> BIOS v2.7.1 LOADED ............ <span class="ok">[OK]</span></div>
    <div class="line dim" style="animation-delay: 1500ms">> CHECKSUM 0x4F2A8B ............. <span class="ok">[OK]</span></div>
    <div class="line dim" style="animation-delay: 1800ms">> MEMORY ALLOC 0xFFE0 ........... <span class="ok">[OK]</span></div>
    <div class="line dim" style="animation-delay: 2100ms" id="boot-neural">> NEURAL LINK ................... <span id="boot-neural-status" class="err">[ERR]</span></div>
    <div class="line dim sub" style="animation-delay: 2400ms" id="boot-recover">&nbsp;&nbsp;>> RECONNECT // ALT NODE<span class="dots"></span></div>
    <div class="line dim" style="animation-delay: 3000ms">> PERSONALITY DATA 0x9C1D ....... <span class="ok">[OK]</span></div>
    <div class="line dim" style="animation-delay: 3300ms">> YORHA PROTOCOL v1.42 .......... <span class="ok">[OK]</span></div>
    <div class="line" style="animation-delay: 3600ms">> WELCOME, OPERATOR.</div>
  </div>
</div>

<script>
  const KEY = "boot:v3:played";
  const el = document.getElementById("boot");
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;
  if (!el) {
    /* nothing */
  } else if (prefersReducedMotion || sessionStorage.getItem(KEY)) {
    el.remove();
  } else {
    sessionStorage.setItem(KEY, "1");
    document.body.classList.add("boot-locked");

    const title = document.getElementById("boot-title");
    if (title) {
      const target = title.dataset.text ?? title.textContent ?? "";
      const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!?#@*+=";
      const DURATION = 1100;
      const FRAME = 55;
      const start = performance.now();

      const tick = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / DURATION, 1);
        const settled = Math.floor(target.length * progress);
        let out = "";
        for (let i = 0; i < target.length; i++) {
          if (i < settled || target[i] === " ") {
            out += target[i];
          } else {
            out += CHARS[Math.floor(Math.random() * CHARS.length)];
          }
        }
        title.textContent = out;
        if (progress < 1) {
          setTimeout(() => requestAnimationFrame(tick), FRAME);
        } else {
          title.textContent = target;
        }
      };
      requestAnimationFrame(tick);
    }

    // Simulated error → recovery
    setTimeout(() => {
      const status = document.getElementById("boot-neural-status");
      const recover = document.getElementById("boot-recover");
      if (status) {
        status.textContent = "[OK]";
        status.classList.remove("err");
        status.classList.add("ok");
      }
      if (recover) {
        recover.classList.add("resolved");
      }
    }, 2900);

    setTimeout(() => el.classList.add("fade"), 4300);
    setTimeout(() => {
      el.remove();
      document.body.classList.remove("boot-locked");
    }, 4900);
  }
</script>

<style is:global>
  body.boot-locked {
    overflow: hidden;
  }
</style>

<style>
  #boot {
    position: fixed;
    inset: 0;
    background: var(--ink);
    color: var(--bg);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 600ms ease-out;
  }

  #boot.fade {
    opacity: 0;
  }

  .boot-stack {
    font-family: "Share Tech Mono", monospace;
    line-height: 1.7;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1rem 1.5rem;
  }

  .line {
    visibility: hidden;
    animation: appear 1ms forwards;
  }

  .big {
    font-family: "VT323", monospace;
    font-size: 2.6rem;
    margin-bottom: 0.8rem;
    letter-spacing: 0.14em;
  }

  .dim {
    color: rgba(196, 185, 152, 0.95);
  }

  .sub {
    font-size: 0.85em;
    color: rgba(196, 185, 152, 0.95);
  }

  .sub.resolved {
    visibility: hidden;
  }

  .ok {
    color: var(--accent);
  }

  .err {
    color: var(--warn);
  }

  .dots::after {
    content: "";
    display: inline-block;
    width: 1.2em;
    text-align: left;
    animation: dots 700ms steps(4, end) infinite;
  }

  @keyframes appear {
    to {
      visibility: visible;
    }
  }

  @keyframes dots {
    0% {
      content: "";
    }
    25% {
      content: ".";
    }
    50% {
      content: "..";
    }
    75% {
      content: "...";
    }
  }
</style>
