---
import "../styles/global.css";
import MenuNav from "../components/MenuNav.astro";
import BootSequence from "../components/BootSequence.astro";
import Pod042 from "../components/Pod042.astro";
import { PERSON_JSONLD, jsonLdScript } from "../lib/seo";

type JsonLd = Record<string, unknown>;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  structuredData?: JsonLd | JsonLd[];
}

const {
  title = "Brian Hlonggul // Portfolio",
  description = "Brian Hlonggul — CS undergrad at Cal State Fullerton. Tools, algorithms, small games.",
  image = "/og-image.png",
  structuredData,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("/", Astro.url);
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();

const extraJsonLd: JsonLd[] = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];

const lore = [
  "ROUTINE 042 // PATROL OK",
  "ALL SYSTEMS NOMINAL",
  "GLORY TO MANKIND",
  "SIGNAL STABLE // 99.7%",
  "SCANNING SECTOR ... CLEAR",
  "NO HOSTILES DETECTED",
  "STANDING BY FOR ORDERS",
  "COMMS LINK: GREEN",
  "SUBROUTINE 7E LOOPED",
  "CACHE FLUSH COMPLETE",
  "LISTENING ON CHANNEL ◆",
  "COORDINATES LOCKED",
  "DIRECTIVE 042 ACTIVE",
  "MEMORY INTACT // 87%",
  "THE FLOWERS ARE STILL THERE",
];
const initialLore = lore[Math.floor(Math.random() * lore.length)];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Brian Hlonggul // Portfolio" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline type="application/ld+json" set:html={jsonLdScript(PERSON_JSONLD)} />
    {extraJsonLd.map((data) => (
      <script is:inline type="application/ld+json" set:html={jsonLdScript(data)} />
    ))}
  </head>
  <body>
    <BootSequence />
    <MenuNav />
    <main>
      <slot />
    </main>
    <Pod042 />
    <div id="glitch-toast" aria-live="polite"></div>
    <footer class="foot">
      <div class="foot-inner">
        <span class="foot-side">// END OF TRANSMISSION</span>
        <span
          class="foot-lore"
          id="foot-lore"
          data-lore={JSON.stringify(lore)}>{initialLore}</span>
        <span class="foot-side">{new Date().getFullYear()}</span>
      </div>
    </footer>

    <script>
      import { inject } from "@vercel/analytics";
      const host = window.location.hostname;
      if (host !== "localhost" && host !== "127.0.0.1") inject();
    </script>

    <script>
      const KONAMI = [
        "ArrowUp",
        "ArrowUp",
        "ArrowDown",
        "ArrowDown",
        "ArrowLeft",
        "ArrowRight",
        "ArrowLeft",
        "ArrowRight",
        "b",
        "a",
      ];
      const GLITCH_KEY = "glitch:mode";
      const buf: string[] = [];

      const applyGlitch = (on: boolean) => {
        document.body.classList.toggle("glitch-mode", on);
      };

      const showToast = (msg: string) => {
        const t = document.getElementById("glitch-toast");
        if (!t) return;
        t.textContent = msg;
        t.classList.add("show");
        window.setTimeout(() => t.classList.remove("show"), 1500);
      };

      try {
        applyGlitch(localStorage.getItem(GLITCH_KEY) === "1");
      } catch {
        /* localStorage unavailable; ignore */
      }

      window.addEventListener("keydown", (e) => {
        const target = e.target as HTMLElement | null;
        const tag = target?.tagName;
        if (tag === "INPUT" || tag === "TEXTAREA" || target?.isContentEditable) {
          return;
        }
        const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
        buf.push(key);
        if (buf.length > KONAMI.length) buf.shift();
        if (
          buf.length === KONAMI.length &&
          buf.every((k, i) => k === KONAMI[i])
        ) {
          const next = !document.body.classList.contains("glitch-mode");
          applyGlitch(next);
          try {
            localStorage.setItem(GLITCH_KEY, next ? "1" : "0");
          } catch {
            /* ignore */
          }
          showToast(`GLITCH MODE: ${next ? "ON" : "OFF"}`);
          buf.length = 0;
        }
      });
    </script>

    <script>
      const loreEl = document.getElementById("foot-lore");
      if (loreEl?.dataset.lore) {
        try {
          const list = JSON.parse(loreEl.dataset.lore) as string[];
          if (Array.isArray(list) && list.length > 0) {
            loreEl.textContent = list[Math.floor(Math.random() * list.length)];
          }
        } catch {
          /* leave server-rendered fallback */
        }
      }
    </script>

    <script>
      const targets = document.querySelectorAll<HTMLElement>("[data-stagger]");
      if (targets.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                observer.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
        );
        targets.forEach((el) => observer.observe(el));
      }
    </script>

    <style>
      .foot {
        border-top: var(--line) solid var(--ink);
        background: var(--bg-deep);
      }

      .foot-inner {
        max-width: var(--content-max);
        margin: 0 auto;
        padding: 0.85rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 1.25rem;
        align-items: center;
        justify-content: space-between;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ink);
      }

      .foot-side {
        flex: 0 0 auto;
      }

      .foot-lore {
        flex: 1 1 auto;
        text-align: center;
        min-width: 0;
        color: var(--ink);
      }

      @media (max-width: 540px) {
        .foot-lore {
          flex-basis: 100%;
          order: 3;
          text-align: left;
        }
      }
    </style>
  </body>
</html>
